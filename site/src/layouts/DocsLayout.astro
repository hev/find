---
import Base from "./Base.astro";
import {
	getDocHref,
	getDocNavGroups,
	getDocSiblings,
	type DocEntry,
} from "../lib/docs";

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	entry: DocEntry;
	headings: Heading[];
}

const { entry, headings } = Astro.props;
const navGroups = await getDocNavGroups();
const { previous, next } = await getDocSiblings(entry.id);
const tocHeadings = headings.filter((heading) => heading.depth === 2);
---

<Base title={`hev ask docs - ${entry.data.title}`} description={entry.data.description} current="docs">
	<div class="docs-announcement">
		<a href="/docs/quickstart">Add search in five minutes</a>
		<span>or press ⌘K to watch it search these docs.</span>
	</div>

	<main class="docs-shell">
		<aside class="docs-sidebar" aria-label="Docs navigation">
			<button type="button" class="sidebar-search" data-hev-ask-open>
				<span>Search docs</span>
				<kbd>⌘K</kbd>
			</button>

			<nav class="docs-nav">
				{
					navGroups.map((group) => (
						<section class="nav-group" aria-labelledby={`nav-${group.label}`}>
							<h2 id={`nav-${group.label}`}>{group.label}</h2>
							<ul>
								{group.items.map((item) => (
									<li>
										<a
											href={getDocHref(item.id)}
											aria-current={item.id === entry.id ? "page" : undefined}
										>
											{item.data.title}
										</a>
									</li>
								))}
							</ul>
						</section>
					))
				}
			</nav>
		</aside>

		<article class="docs-content">
			<header class="doc-header">
				<p class="eyebrow">{entry.data.group}</p>
				<h1>{entry.data.title}</h1>
			</header>

			<div class="doc-body">
				<slot />
			</div>

			<nav class="doc-pagination" aria-label="Docs pagination">
				{
					previous ? (
						<a href={getDocHref(previous.id)} class="pager prev">
							<span>previous</span>
							{previous.data.title}
						</a>
					) : (
						<span></span>
					)
				}
				{
					next && (
						<a href={getDocHref(next.id)} class="pager next">
							<span>next</span>
							{next.data.title}
						</a>
					)
				}
			</nav>
		</article>

		<aside class="docs-toc" aria-label="On this page">
			<button type="button" data-copy-page>copy page</button>
			<h2>On this page</h2>
			<nav>
				{
					tocHeadings.map((heading) => (
						<a href={`#${heading.slug}`}>{heading.text}</a>
					))
				}
			</nav>
		</aside>
	</main>

	<script is:inline>
		document.querySelector("[data-copy-page]")?.addEventListener("click", async (event) => {
			const button = event.currentTarget;
			try {
				await navigator.clipboard.writeText(window.location.href);
				button.textContent = "copied";
				setTimeout(() => {
					button.textContent = "copy page";
				}, 1400);
			} catch {
				button.textContent = "copy failed";
				setTimeout(() => {
					button.textContent = "copy page";
				}, 1400);
			}
		});
	</script>
</Base>

<style>
	.docs-announcement {
		border-bottom: 1px solid var(--rule);
		background: var(--paper-warm);
		color: var(--ink-soft);
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.75rem;
		padding: 0.65rem 2rem;
		text-align: center;
	}

	.docs-announcement a {
		color: var(--signal);
		font-weight: 700;
		text-decoration: none;
	}

	.docs-announcement a:hover {
		color: var(--signal-dark);
	}

	.docs-announcement span {
		color: var(--muted);
		margin-left: 0.35rem;
	}

	.docs-shell {
		width: var(--page);
		margin: 0 auto;
		padding: 2rem 0 5rem;
		display: grid;
		grid-template-columns: 230px minmax(0, 1fr) 190px;
		gap: 2.5rem;
		align-items: start;
	}

	.docs-sidebar,
	.docs-toc {
		position: sticky;
		top: 5rem;
	}

	.docs-nav h2,
	.docs-toc h2,
	.eyebrow {
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.sidebar-search {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		width: 100%;
		margin-bottom: 1.5rem;
		padding: 0.6rem 0.75rem;
		border: 1px solid var(--rule-strong);
		border-radius: 2px;
		background: var(--paper-warm);
		color: var(--muted);
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.8125rem;
		cursor: pointer;
		transition: border-color 0.15s ease, color 0.15s ease;
	}

	.sidebar-search:hover {
		border-color: var(--signal);
		color: var(--ink);
	}

	.sidebar-search kbd {
		font-family: inherit;
		font-size: 0.6875rem;
		padding: 0.1rem 0.35rem;
		border: 1px solid var(--rule-strong);
		border-radius: 3px;
	}

	.docs-nav {
		display: flex;
		flex-direction: column;
		gap: 1.65rem;
	}

	.nav-group h2,
	.docs-toc h2 {
		margin-bottom: 0.75rem;
	}

	.nav-group ul {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}

	.nav-group a,
	.docs-toc a {
		display: block;
		color: var(--ink-soft);
		text-decoration: none;
		font-size: 0.875rem;
		line-height: 1.35;
		padding: 0.15rem 0;
	}

	.nav-group a:hover,
	.nav-group a[aria-current="page"],
	.docs-toc a:hover {
		color: var(--signal);
	}

	.docs-content {
		min-width: 0;
		max-width: var(--measure);
	}

	.doc-header {
		padding: 2rem 0 0;
		margin-bottom: 2rem;
	}

	.eyebrow {
		color: var(--signal);
		margin-bottom: 1rem;
	}

	h1,
	.doc-body :global(h2) {
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		letter-spacing: 0;
	}

	h1 {
		font-size: 3rem;
		line-height: 1.05;
		margin-bottom: 1rem;
	}

	.doc-header p {
		color: var(--ink-soft);
		font-size: 1.0625rem;
		max-width: 620px;
	}

	.doc-body :global(h2) {
		font-size: 1.15rem;
		margin: 3.25rem 0 1rem;
		scroll-margin-top: 6rem;
	}

	.doc-body :global(h2:first-child) {
		margin-top: 0;
	}

	.doc-body :global(p) {
		color: var(--ink-soft);
		margin-bottom: 1rem;
	}

	.doc-body :global(ul) {
		list-style: disc outside;
		padding: 0;
		padding-left: 1.25rem;
		margin: 1rem 0;
	}

	.doc-body :global(ul li) {
		color: var(--ink-soft);
		line-height: 1.45;
		margin: 0.25rem 0;
		padding-left: 0.25rem;
	}

	.doc-body :global(ul li::marker) {
		color: var(--signal);
	}

	.doc-body :global(.steps) {
		counter-reset: step;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 0;
		margin: 1rem 0;
	}

	.doc-body :global(.steps li) {
		counter-increment: step;
		position: relative;
		padding: 1rem 1rem 1rem 3.5rem;
		border: 1px solid var(--rule);
		background: var(--paper-warm);
	}

	.doc-body :global(.steps li::before) {
		content: counter(step, decimal-leading-zero);
		position: absolute;
		left: 1rem;
		top: 1rem;
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.8125rem;
		color: var(--signal);
	}

	.doc-body :global(.steps strong) {
		display: block;
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.9375rem;
		color: var(--ink);
		margin-bottom: 0.25rem;
	}

	.doc-body :global(.steps li span) {
		color: var(--ink-soft);
		font-size: 0.9375rem;
	}

	.doc-body :global(.callout) {
		margin: 1.5rem 0;
		padding: 1.25rem 1.5rem;
		border-left: 3px solid var(--signal);
		background: var(--paper-warm);
	}

	.doc-body :global(.callout > span) {
		display: block;
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.75rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ink);
		margin-bottom: 0.45rem;
	}

	.doc-body :global(.callout > span::before) {
		content: "// ";
		color: var(--signal);
	}

	.doc-body :global(.callout p) {
		margin: 0;
	}

	.doc-body :global(.upstream) {
		margin: 1.5rem 0;
		padding: 1rem 1.25rem;
		border: 1px dashed var(--rule-strong);
		background: transparent;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.doc-body :global(.upstream-label) {
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.7rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--ink-soft);
	}

	.doc-body :global(.upstream-label::before) {
		content: "↗ ";
		color: var(--signal);
	}

	.doc-body :global(.upstream-body p) {
		margin: 0;
		color: var(--ink-soft);
		font-size: 0.9375rem;
	}

	.doc-body :global(.upstream-link) {
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.8125rem;
		color: var(--signal);
		text-decoration: none;
		align-self: flex-start;
	}

	.doc-body :global(.upstream-link:hover) {
		text-decoration: underline;
	}

	.doc-body :global(pre) {
		position: relative;
		background: var(--paper-warm);
		border: 1px solid var(--rule);
		border-radius: 2px;
		color: var(--ink-soft);
		overflow-x: auto;
		padding: 1.4rem 1.2rem;
		margin: 1.25rem 0;
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.8125rem;
		line-height: 1.6;
	}

	.doc-body :global(.diagram),
	.doc-body :global(.diagram code) {
		line-height: 1;
		font-variant-ligatures: none;
		font-feature-settings: "liga" 0, "calt" 0, "kern" 0;
		letter-spacing: 0;
		text-rendering: geometricPrecision;
		font-size: 0.7rem;
	}

	.doc-body :global(pre code) {
		background: transparent;
		padding: 0;
		color: inherit;
		border-radius: 0;
		white-space: pre;
	}

	.doc-body :global(table) {
		width: 100%;
		border-collapse: collapse;
		min-width: 520px;
		margin: 1.25rem 0;
		border: 1px solid var(--rule);
	}

	.doc-body :global(th),
	.doc-body :global(td) {
		text-align: left;
		vertical-align: top;
		padding: 0.8rem 0.9rem;
		border-bottom: 1px solid var(--rule);
	}

	.doc-body :global(th) {
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.75rem;
		color: var(--muted);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		background: var(--paper-warm);
	}

	.doc-body :global(td) {
		color: var(--ink-soft);
		font-size: 0.9375rem;
	}

	.doc-body :global(tr:last-child td) {
		border-bottom: none;
	}

	.doc-body :global(.link-grid) {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.8rem;
		margin: 1.25rem 0;
	}

	.doc-body :global(.doc-card) {
		min-height: 9rem;
		border: 1px solid var(--rule);
		background: var(--paper-warm);
		padding: 1rem;
		text-decoration: none;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.doc-body :global(.doc-card:hover) {
		border-color: var(--signal);
	}

	.doc-body :global(.doc-card strong) {
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		color: var(--signal);
	}

	.doc-body :global(.doc-card span) {
		color: var(--ink-soft);
		font-size: 0.875rem;
		line-height: 1.45;
	}

	.doc-pagination {
		border-top: 1px solid var(--rule);
		padding-top: 1.5rem;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	.pager {
		border: 1px solid var(--rule);
		padding: 1rem;
		text-decoration: none;
		color: var(--ink);
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.875rem;
	}

	.pager:hover {
		border-color: var(--signal);
	}

	.pager span {
		display: block;
		color: var(--muted);
		font-size: 0.6875rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		margin-bottom: 0.35rem;
	}

	.next {
		text-align: right;
	}

	.docs-toc {
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.8125rem;
		color: var(--muted);
	}

	.docs-toc button {
		width: 100%;
		border: 1px solid var(--rule-strong);
		background: transparent;
		color: var(--ink-soft);
		border-radius: 2px;
		padding: 0.55rem 0.65rem;
		margin-bottom: 1.25rem;
		cursor: pointer;
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.75rem;
		text-align: left;
	}

	.docs-toc button:hover {
		color: var(--signal);
		border-color: var(--signal);
	}

	.docs-toc nav {
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
	}

	@media (max-width: 1040px) {
		.docs-shell {
			grid-template-columns: 220px minmax(0, 1fr);
		}

		.docs-toc {
			display: none;
		}
	}

	@media (max-width: 760px) {
		.docs-announcement {
			padding: 0.65rem 1.25rem;
			text-align: left;
		}

		.docs-shell {
			width: min(100% - 2rem, 720px);
			display: block;
			padding: 1.5rem 0 4rem;
		}

		.docs-sidebar {
			position: relative;
			top: auto;
			margin-bottom: 2rem;
		}

		.docs-nav {
			border: 1px solid var(--rule);
			background: var(--paper-warm);
			padding: 1rem;
			max-height: 17rem;
			overflow: auto;
		}

		.doc-header {
			padding-top: 0;
		}

		h1 {
			font-size: 2.25rem;
		}

		.link-grid,
		.doc-pagination {
			grid-template-columns: 1fr;
		}

		.next {
			text-align: left;
		}

		.doc-body :global(pre) {
			font-size: 0.75rem;
		}
	}
</style>
