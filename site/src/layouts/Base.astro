---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SearchOverlay from "@hev/ask/components/SearchOverlay.astro";

interface Props {
	title: string;
	description?: string;
	current?: "product" | "docs";
}

const {
	title,
	description = "hev ask is a ⌘K search overlay for Astro docs sites: instant keyword search over heading anchors, plus an optional Claude-powered search loop on Enter.",
	current = "product",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<Header current={current} />
		<slot />
		<Footer />
		<!-- This site searches itself with hev ask: the docs are the corpus. -->
		<SearchOverlay />
	</body>
</html>
