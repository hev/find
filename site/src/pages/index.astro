---
import Base from "../layouts/Base.astro";

// Shared hev-mind-workspace Loops form (one form per workspace); userGroup
// keeps ask signups filterable from mind/layer ones.
const LOOPS_FORM_ID = "cmgjf63rked6g3d0i3n0hyrai";
const LOOPS_USER_GROUP = "hev ask";
const loopsAction = `https://app.loops.so/api/newsletter-form/${LOOPS_FORM_ID}`;

const facts = [
	{ k: "readers", v: "⌘K — instant keyword search; Enter streams a grounded Claude answer" },
	{ k: "agents", v: "ask tree · cat · grep — your docs as a directory, keyless, from any shell" },
	{ k: "cited", v: "every answer deep-links to the exact heading — anchors verified in CI" },
];
---

<Base
	title="hev ask - your docs as a directory your agent can read"
	description="hev ask distills your docs into a compact directory of markdown your coding agent can tree, cat, and grep, plus a ⌘K overlay that answers your readers. It ships a turnkey Astro integration, every other framework adds one script, and every citation is a CI-verified anchor."
	current="product"
>
	<main>
		<section class="hero">
			<p class="kicker">// your docs as a directory your agent can read</p>
			<h1>Your docs,<br />agent ready.</h1>
			<p class="lede">
				Distill your docs into a tree of markdown files your coding
				agent can intuitively <span class="mono">cat</span> and
				<span class="mono">grep</span>, plus a
				<span class="mono">⌘K</span> overlay that searches your
				docs site. The core is framework-neutral, the Astro
				integration is first-class, and you never pay by the token.
			</p>
			<div class="cta-row">
				<a href="/docs" class="btn">Read the docs</a>
				<button type="button" class="ghost" data-hev-ask-open>
					press <kbd>⌘K</kbd> to search this site
				</button>
			</div>

			<figure class="hero-art">
				<img
					src="/digest.png"
					width="1376"
					height="768"
					alt="A stack of documentation pages distilled into a directory tree of markdown section files on warm paper, read two equal ways: an orange ⌘K beam for readers and an `ask` terminal running tree, cat, and grep for agents — both unfolding the same section, anchored at #api/endpoints/create."
					loading="eager"
				/>
			</figure>
		</section>

		<section class="install" aria-label="The whole setup">
			<ol class="steps">
				<li>
					<span class="step-label">build the digest</span>
					<pre><code><span class="cmt">// offline — distils your markdown into the .hev-ask/ tree</span>
ask digest build</code></pre>
				</li>
				<li>
					<span class="step-label">add the overlay</span>
					<pre><code><span class="cmt">// any layout — the Astro integration, or one script elsewhere</span>
&lt;SearchOverlay /&gt;</code></pre>
				</li>
				<li>
					<span class="step-label">optional — single-turn Q&amp;A</span>
					<pre><code><span class="cmt">// add a key to stream a grounded answer on Enter</span>
ANTHROPIC_API_KEY=sk-…</code></pre>
				</li>
			</ol>
			<p class="caption">
				That's the whole setup, the same on any framework — this site runs on it.
				Keyword search needs no API key; add one only for single-turn Q&amp;A.
				<a href="/docs/quickstart">Quick start →</a>
			</p>
		</section>

		<section class="install agents" aria-label="What their agents get">
			<p class="kicker">// and for their agents</p>
			<ol class="steps">
				<li>
					<span class="step-label">install the CLI — no config</span>
					<pre><code>go install github.com/hev/ask/cmd/ask@latest</code></pre>
				</li>
				<li>
					<span class="step-label">browse any hev-ask site as a directory</span>
					<pre><code>ask --endpoint https://yourdocs.com/api/ask tree
ask --endpoint https://yourdocs.com/api/ask cat overview/quick-start</code></pre>
				</li>
			</ol>
			<p class="caption">
				Your docs become a directory any agent can navigate:
				<span class="mono">tree</span> the map, <span class="mono">cat</span>
				a section, <span class="mono">grep</span> for a string — every read
				keyless, every citation a CI-verified anchor. Or wire up MCP: one tool
				hydrates the whole tree to disk and the agent reads it with the
				file tools it already has.
				<a href="/docs/api/cli">CLI reference →</a>
			</p>
		</section>

		<section class="facts" aria-label="What the reader gets">
			<ul>
				{
					facts.map((f) => (
						<li>
							<span class="fk">{f.k}</span>
							<span class="fv">{f.v}</span>
						</li>
					))
				}
			</ul>

			<a href="/digest" class="digest-peek">
				<span class="digest-peek-label">// show, don't tell</span>
				<strong>See what the agent sees →</strong>
				<span class="digest-peek-note">
					The ask digest for this site, rendered — the tree of distilled
					section files, with the summaries and verbatim facts your agent
					reads. Committed, per-section, reviewable.
				</span>
			</a>

			<p class="more">
				<a href="/docs/concepts">how it works</a>
				<a href="/docs/tradeoffs">tradeoffs</a>
				<a href="/docs/limits">limits</a>
				<a href="https://github.com/hev/ask">source</a>
			</p>
		</section>

		<section class="pitch" aria-label="The pitch, second">
			<p class="kicker">// the pitch, second</p>
			<p class="pitch-line">
				ask is free and open source, built by
				<a href="https://hevmind.com">hev mind</a> — Adam Hevenor's search
				engineering practice. If you want to go deeper than your docs —
				training your team on agent-ready design, hands-on search
				engineering, or taking a retrieval workload to production:
			</p>
			<p class="more pitch-links">
				<a href="https://hevmind.com/agent-ready">
					training — make your product agent-ready
				</a>
				<a href="https://hevmind.com/services">work with the practice</a>
				<a href="https://hevlayer.com">production retrieval — hev layer</a>
			</p>

			<form
				class="loops-form"
				action={loopsAction}
				method="POST"
				data-form="ask-loop"
			>
				<input type="hidden" name="userGroup" value={LOOPS_USER_GROUP} />
				<label for="loop-email">
					New adapters, new patterns, no noise — stay in the loop.
				</label>
				<div class="loop-row">
					<input
						id="loop-email"
						name="email"
						type="email"
						required
						autocomplete="email"
						placeholder="you@company.com"
					/>
					<button type="submit">stay in the loop</button>
				</div>
				<p class="loop-note" data-role="status" aria-live="polite"></p>
			</form>
		</section>
	</main>

	<script is:inline>
		(function () {
			const form = document.querySelector("form.loops-form");
			if (!form) return;
			const status = form.querySelector('[data-role="status"]');
			form.addEventListener("submit", async (e) => {
				e.preventDefault();
				const data = new FormData(form);
				const email = String(data.get("email") || "").trim();
				const userGroup = String(data.get("userGroup") || "");
				if (!email) return;
				if (status) status.textContent = "sending...";
				try {
					const res = await fetch(form.action, {
						method: "POST",
						body: new URLSearchParams({ email, userGroup }),
						headers: {
							"Content-Type": "application/x-www-form-urlencoded",
						},
					});
					if (!res.ok) throw new Error(String(res.status));
					if (status) status.textContent = "got it — talk soon.";
					form.reset();
				} catch {
					if (status)
						status.textContent = "something broke — try again in a bit.";
				}
			});
		})();
	</script>
</Base>

<style>
	main {
		width: var(--page);
		max-width: 820px;
		margin: 0 auto;
		padding: 4rem 0 2rem;
	}

	.kicker {
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
		font-size: 0.75rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--signal);
		margin-bottom: 1.5rem;
	}

	h1 {
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
		font-size: 3.25rem;
		line-height: 1.05;
		letter-spacing: -0.02em;
		margin-bottom: 1.5rem;
	}

	.lede {
		color: var(--ink-soft);
		font-size: 1.1875rem;
		line-height: 1.6;
		max-width: 36em;
		margin-bottom: 2rem;
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 1rem;
	}

	.btn {
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		background: var(--ink);
		color: var(--paper);
		border: 1px solid var(--ink);
		border-radius: 2px;
		text-decoration: none;
		padding: 0.7rem 1.1rem;
		font-size: 0.9375rem;
		transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
	}

	.btn::before {
		content: "$";
		color: var(--signal);
	}

	.btn:hover {
		background: transparent;
		color: var(--signal);
		border-color: var(--signal);
	}

	.ghost {
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
		background: none;
		border: 0;
		color: var(--muted);
		font-size: 0.875rem;
		cursor: pointer;
		padding: 0;
	}

	.ghost:hover {
		color: var(--signal);
	}

	.ghost kbd {
		font-family: inherit;
		font-size: 0.8em;
		padding: 0.1em 0.4em;
		border: 1px solid var(--rule-strong);
		border-radius: 3px;
		color: var(--ink-soft);
	}

	.hero-art {
		margin-top: 2.5rem;
	}

	.hero-art img {
		display: block;
		width: 100%;
		height: auto;
		border: 1px solid var(--rule-strong);
		border-radius: 2px;
		background: var(--paper-warm);
	}

	.install {
		margin-top: 3rem;
		padding-top: 2.75rem;
		border-top: 1px solid var(--rule);
	}

	.steps {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		counter-reset: step;
	}

	.steps li {
		counter-increment: step;
	}

	.step-label {
		display: block;
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
		font-size: 0.75rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted);
		margin-bottom: 0.55rem;
	}

	.step-label::before {
		content: counter(step, decimal-leading-zero) " · ";
		color: var(--signal);
	}

	.install pre {
		background: var(--paper-warm);
		border: 1px solid var(--rule-strong);
		border-left: 2px solid var(--signal);
		border-radius: 2px;
		padding: 0.85rem 1.1rem;
		overflow-x: auto;
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
		font-size: 0.875rem;
		line-height: 1.6;
		color: var(--ink);
	}

	.install pre code {
		background: transparent;
		padding: 0;
		color: var(--ink);
	}

	.cmt {
		color: var(--muted);
	}

	.caption {
		margin-top: 1.75rem;
		color: var(--muted);
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.caption a {
		color: var(--signal);
		text-decoration: none;
	}

	.caption a:hover {
		text-decoration: underline;
	}

	.facts {
		margin-top: 4rem;
		padding-top: 3rem;
		border-top: 1px solid var(--rule);
	}

	.facts ul {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.facts li {
		display: grid;
		grid-template-columns: 5.5rem 1fr;
		gap: 1rem;
		align-items: baseline;
	}

	.fk {
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
		font-size: 0.8125rem;
		color: var(--signal);
		text-align: right;
	}

	.fk::before {
		content: "⏎ ";
		opacity: 0.5;
	}

	.facts li:first-child .fk::before {
		content: "⌨ ";
	}

	.facts li:nth-child(2) .fk::before {
		content: "$ ";
	}

	.install.agents {
		margin-top: 2.75rem;
	}

	.install.agents .kicker {
		margin-bottom: 1.25rem;
	}

	.fv {
		color: var(--ink-soft);
		font-size: 1rem;
		line-height: 1.5;
	}

	.digest-peek {
		display: block;
		margin-top: 2.5rem;
		padding: 1.25rem 1.4rem;
		background: var(--paper-warm);
		border: 1px solid var(--rule-strong);
		border-radius: 2px;
		text-decoration: none;
		transition: border-color 0.15s ease;
	}

	.digest-peek:hover {
		border-color: var(--signal);
	}

	.digest-peek-label {
		display: block;
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
		font-size: 0.7rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--signal);
		margin-bottom: 0.5rem;
	}

	.digest-peek strong {
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
		font-size: 1.0625rem;
		color: var(--ink);
	}

	.digest-peek-note {
		display: block;
		margin-top: 0.4rem;
		color: var(--muted);
		font-size: 0.875rem;
		line-height: 1.55;
		max-width: 44em;
	}

	.pitch {
		margin-top: 4rem;
		padding-top: 2.5rem;
		border-top: 1px solid var(--rule);
	}

	.pitch .kicker {
		margin-bottom: 1rem;
	}

	.pitch-line {
		color: var(--muted);
		font-size: 0.9375rem;
		line-height: 1.6;
		max-width: 44em;
	}

	.pitch-line a {
		color: var(--signal);
		text-decoration: none;
	}

	.pitch-line a:hover {
		text-decoration: underline;
	}

	.pitch-links {
		margin-top: 1.25rem;
	}

	.loops-form {
		margin-top: 2.5rem;
		padding-top: 2rem;
		border-top: 1px dashed var(--rule);
		max-width: 30rem;
	}

	.loops-form label {
		display: block;
		font-size: 0.9375rem;
		color: var(--muted);
		margin-bottom: 0.75rem;
		line-height: 1.5;
	}

	.loop-row {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.loop-row input[type="email"] {
		flex: 1;
		min-width: 12rem;
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
		font-size: 0.875rem;
		padding: 0.65rem 0.85rem;
		border: 1px solid var(--rule-strong);
		border-radius: 2px;
		background: var(--paper-warm);
		color: var(--ink);
	}

	.loop-row input[type="email"]:focus {
		outline: none;
		border-color: var(--signal);
	}

	.loop-row button {
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
		font-size: 0.875rem;
		border: 1px solid var(--ink);
		border-radius: 2px;
		background: var(--ink);
		color: var(--paper);
		padding: 0.65rem 1rem;
		cursor: pointer;
		transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
	}

	.loop-row button:hover {
		background: transparent;
		color: var(--signal);
		border-color: var(--signal);
	}

	.loop-note {
		margin-top: 0.6rem;
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
		font-size: 0.8125rem;
		color: var(--muted);
	}

	.more {
		margin-top: 2rem;
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
		font-size: 0.875rem;
	}

	.more a {
		color: var(--muted);
		text-decoration: none;
	}

	.more a::before {
		content: "→ ";
		color: var(--signal);
	}

	.more a:hover {
		color: var(--signal);
	}

	@media (max-width: 640px) {
		main {
			width: min(100% - 2rem, 720px);
			padding: 3rem 0 4rem;
		}

		h1 {
			font-size: 2.25rem;
		}

		.lede {
			font-size: 1.0625rem;
		}

		.facts li {
			grid-template-columns: 1fr;
			gap: 0.2rem;
		}

		.fk {
			text-align: left;
		}
	}
</style>
